{
  "name": "cup-to-gram",
  "type": "module",
  "version": "1.0.0",
  "description": "Browser extension that converts cup measurements to grams on recipe websites",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "postinstall": "wxt prepare",
    "prepare": "wxt prepare",
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "test": "jest",
    "lint": "biome lint ./src",
    "format": "biome format ./src",
    "format:check": "biome format --check ./src"
  },
  "dependencies": {
    "vitest": "4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/chrome": "0.1.40",
    "@types/node": "25.6.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3",
    "wxt": "0.20.25"
  }
}