{
	"extends": "plasmo/templates/tsconfig.base",
	"compilerOptions": {
		"moduleResolution": "bundler",
		"module": "esnext",
		"strict": true,
		"types": ["chrome"],
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": [".plasmo/index.d.ts", "src/**/*.ts"],
	"exclude": ["node_modules", "src/**/__tests__/**/*.test.ts"]
}
